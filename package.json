{
	"name": "backend",
	"version": "0.0.1",
	"description": "",
	"private": true,
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/src/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"prettier": "prettier . --check",
		"prettier:fix": "prettier . --write",
		"lint-staged": "lint-staged",
		"validate-branch-name": "validate-branch-name",
		"migration:generate": "npm run build && npx typeorm -d dist/src/core/database/sql/sql.config.js migration:generate src/core/database/sql/migrations/%npm_config_name%",
		"migration:create": "npx typeorm migration:create ./src/core/database/sql/migrations/%npm_config_name%",
		"migrate:up": "npx typeorm migration:run -d dist/src/core/database/sql/sql.config.js",
		"migrate:status": "npx typeorm migration:show -d dist/src/core/database/sql/sql.config.js",
		"migrate:revert": "npx typeorm migration:revert -d dist/src/core/database/sql/sql.config.js",
		"seed:create": "npx typeorm-extension seed:create --root src/core/database/sql/seeders/ --name %npm_config_name%",
		"seed:up": "npx typeorm-extension seed:run --dataSource dist/src/core/database/sql/sql.config.js ",
		"migrate:local:up": "npm run build && npm run migrate:up",
		"migrate:local:status": "npm run build && npm run migrate:status",
		"migrate:local:revert": "npm run build && npm run migrate:revert",
		"seed:local:up": "npm run build && npm run seed:up",
		"prepare": "husky"
	},
	"dependencies": {
		"@faker-js/faker": "^9.9.0",
		"@fastify/cookie": "^11.0.2",
		"@fastify/static": "^8.1.1",
		"@nestjs/axios": "^4.0.0",
		"@nestjs/common": "^11.1.0",
		"@nestjs/config": "^4.0.2",
		"@nestjs/core": "^11.1.0",
		"@nestjs/jwt": "^11.0.0",
		"@nestjs/mongoose": "^11.0.3",
		"@nestjs/passport": "^11.0.5",
		"@nestjs/platform-fastify": "^11.1.0",
		"@nestjs/swagger": "^11.2.0",
		"@nestjs/typeorm": "^11.0.0",
		"argon2": "^0.43.0",
		"axios": "^1.9.0",
		"dotenv": "^17.2.0",
		"fastify": "^5.3.3",
		"firebase-admin": "^12.7.0",
		"generate-api-key": "^1.0.2",
		"google-auth-library": "^10.3.0",
		"ioredis": "^5.6.1",
		"ip-location-api": "^3.0.2",
		"moment": "^2.30.1",
		"mongoose": "^8.16.3",
		"nestjs-zod": "^4.3.1",
		"passport": "^0.7.0",
		"pg": "^8.15.6",
		"reflect-metadata": "^0.2.2",
		"swagger-ui-express": "^5.0.1",
		"typeorm": "^0.3.22",
		"typeorm-extension": "^3.7.1",
		"ua-parser-js": "^2.0.3",
		"zod": "^3.24.4"
	},
	"devDependencies": {
		"@nestjs/cli": "^11.0.7",
		"@nestjs/schematics": "^11.0.5",
		"@nestjs/testing": "^11.1.0",
		"@types/express": "^5.0.1",
		"@types/node": "^22.15.12",
		"@types/passport-google-oauth20": "^2.0.16",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"eslint": "^8.2.0",
		"eslint-config-airbnb-base": "^15.0.0",
		"eslint-config-airbnb-typescript": "^18.0.0",
		"eslint-config-prettier": "^10.1.5",
		"eslint-plugin-import": "^2.25.2",
		"eslint-plugin-prettier": "^5.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^15.5.2",
		"prettier": "^3.5.3",
		"prettier-plugin-organize-imports": "^4.1.0",
		"source-map-support": "^0.5.21",
		"ts-loader": "^9.5.2",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.8.3",
		"validate-branch-name": "^1.3.2"
	}
}
